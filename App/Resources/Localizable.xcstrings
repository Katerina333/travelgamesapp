    "home.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Screen-light games for the whole car — fully offline."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Juegos con poca pantalla para todo el auto, sin conexión."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Jogos com pouca tela para o carro todo — totalmente offline."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ігри для всієї родини майже без екрана — повністю офлайн."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Des jeux presque sans écran pour toute la voiture — hors ligne."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Des jeux presque sans écran pour toute la voiture — hors ligne."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "全家人的少屏游戏——完全离线。"
          }
        }
      }
    },
