# Fastlane lanes (§8.3). Signing: Xcode automatic (cloud-managed) with the
# App Store Connect API key from /keys/ (never committed).

default_platform(:ios)

platform :ios do
  before_all do
    # xcodegen keeps the project file out of git churn.
    sh("cd .. && xcodegen generate")
  end

  # Repo root, independent of fastlane's working directory.
  def repo_root
    File.expand_path("..", __dir__)
  end

  def key_path
    File.expand_path(ENV.fetch("ASC_KEY_PATH"), repo_root)
  end

  def asc_api_key
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: key_path
    )
  end

  # Cloud-managed signing needs the API key passed to xcodebuild itself.
  def signing_xcargs
    "-allowProvisioningUpdates " \
      "-authenticationKeyPath #{key_path} " \
      "-authenticationKeyID #{ENV.fetch('ASC_KEY_ID')} " \
      "-authenticationKeyIssuerID #{ENV.fetch('ASC_ISSUER_ID')}"
  end

  # Unique, monotonically increasing build number (UTC timestamp).
  def next_build_number
    Time.now.utc.strftime("%Y%m%d%H%M")
  end

  desc "Resolve packages, run tests, build a Release archive"
  lane :build do
    run_tests(
      project: "MileQuest.xcodeproj",
      scheme: "MileQuest",
      device: "iPhone 17 Pro"
    )
  end

  desc "Upload a beta build to TestFlight"
  lane :beta do
    api_key = asc_api_key
    build_app(
      project: "MileQuest.xcodeproj",
      scheme: "MileQuest",
      export_method: "app-store",
      xcargs: "#{signing_xcargs} CURRENT_PROJECT_VERSION=#{next_build_number}",
      export_xcargs: signing_xcargs
    )
    pilot(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Upload localised store metadata only (no build, no screenshots)"
  lane :metadata do
    api_key = asc_api_key
    deliver(
      api_key: api_key,
      app_version: "1.0.0",
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      metadata_path: "./fastlane/metadata"
    )
  end

  desc "Archive and upload build + localised metadata to App Store Connect"
  lane :release do
    api_key = asc_api_key
    build_app(
      project: "MileQuest.xcodeproj",
      scheme: "MileQuest",
      export_method: "app-store",
      xcargs: "#{signing_xcargs} CURRENT_PROJECT_VERSION=#{next_build_number}",
      export_xcargs: signing_xcargs
    )
    deliver(
      api_key: api_key,
      submit_for_review: false,
      automatic_release: false,
      force: true,
      run_precheck_before_submit: false,
      metadata_path: "./fastlane/metadata"
    )
  end
end
